@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using PaginaWebCoperex.Services.AuthorizationServices
@using PaginaWebCoperex.Services.LoginServices
@using MudBlazor

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject CustomAuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject IRoleAuthorizationService RoleAuth

@implements IDisposable



<!-- ===== DESKTOP ===== -->
<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
          Style="width: 100%;" Class="d-none d-md-flex">

    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        <img src="/ImagenesMyF/LogoCoperex.jpg" style="height: 42px;" />
        <MudText Typo="Typo.h6" Style="font-weight: 600; color: white;">COPEREX</MudText>
    </MudStack>

    <MudSpacer />

    <MudButton Href="/" StartIcon="@Icons.Material.Filled.Home"
               Color="Color.Inherit" Variant="Variant.Text">Inicio</MudButton>

    <MudButton Href="QuienesSomos" StartIcon="@Icons.Material.Filled.Info"
               Color="Color.Inherit" Variant="Variant.Text">Quiénes Somos</MudButton>

    <MudMenu Label="Nuestros Espacios" EndIcon="@Icons.Material.Filled.ArrowDropDown"
             Color="Color.Inherit" Variant="Variant.Text"
             AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
        <MudMenuItem>Nuestras Áreas</MudMenuItem>
        <MudMenuItem>Patrimonios Nacionales</MudMenuItem>
        <MudMenuItem Href="/Parqueos">Parqueos</MudMenuItem>
        <MudMenuItem>Servicios Adicionales</MudMenuItem>
        <MudMenuItem Href="/ComoLlegar">Cómo llegar</MudMenuItem>
    </MudMenu>

    <MudButton Href="INTERFER" StartIcon="@Icons.Material.Filled.Info"
               Color="Color.Inherit" Variant="Variant.Text">INTERFER</MudButton>

    <MudMenu Label="Publicidad" EndIcon="@Icons.Material.Filled.ArrowDropDown"
             Color="Color.Inherit" Variant="Variant.Text"
             AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
        <MudMenuItem>Eventos</MudMenuItem>
        <MudMenuItem Href="/PromocionMarcas">Promociona tu marca y evento</MudMenuItem>
    </MudMenu>

    <MudMenu Label="Transparencia" EndIcon="@Icons.Material.Filled.ArrowDropDown"
             Color="Color.Inherit" Variant="Variant.Text"
             AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
        <MudMenuItem>Información Pública</MudMenuItem>
        <MudMenuItem>Memorias Laborales</MudMenuItem>
    </MudMenu>

    <AuthorizeView>
        <Authorized>
            @if (CanAccess("Encuestas"))
            {
                <MudMenu Label="Gestión"
                         StartIcon="@Icons.Material.Filled.AdminPanelSettings"
                         EndIcon="@Icons.Material.Filled.ArrowDropDown"
                         Color="Color.Inherit" Variant="Variant.Text">
                    <MudMenuItem Href="Encuesta">Encuestas</MudMenuItem>
                    <MudMenuItem Href="VerRespuestasEncuesta">Respuestas</MudMenuItem>
                    <MudMenuItem Href="/Reportes/ReporteEncuesta">Reportes</MudMenuItem>
                    <MudMenuItem Href="usuarios">Usuarios</MudMenuItem>
                </MudMenu>
            }
            <MudChip T="string" Style="color: white; background-color: rgba(255,255,255,0.15);">
                @_nombreUsuario
            </MudChip>
            <MudIconButton Icon="@Icons.Material.Filled.Logout"
                           Color="Color.Inherit" OnClick="@HandleLogout" />
        </Authorized>
        <NotAuthorized>
            <MudButton Href="Login" StartIcon="@Icons.Material.Filled.Login"
                       Color="Color.Inherit" Variant="Variant.Text">Iniciar Sesión</MudButton>
        </NotAuthorized>
    </AuthorizeView>
</MudStack>

<!-- ===== MÓVIL ===== -->
<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
          Style="width: 100%;" Class="d-flex d-md-none">

    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
        <img src="/ImagenesMyF/LogoCoperex.jpg" style="height: 36px;" />
        <MudText Typo="Typo.subtitle1" Style="font-weight: 600; color: white;">COPEREX</MudText>
    </MudStack>

    <MudIconButton Icon="@Icons.Material.Filled.Menu"
                   Color="Color.Inherit"
                   OnClick="@ToggleDrawer" />
</MudStack>

<!-- ===== DRAWER MÓVIL ===== -->
<MudDrawer @bind-Open="_drawerOpen" Anchor="Anchor.Right"
           Elevation="4" Variant="DrawerVariant.Temporary"
           Width="260px">

    <MudDrawerHeader>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <img src="/ImagenesMyF/LogoCoperex.jpg" style="height: 36px;" />
            <MudText Typo="Typo.h6" Style="font-weight: 600;">COPEREX</MudText>
        </MudStack>
    </MudDrawerHeader>

    <MudNavMenu>
        <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home"
                    Match="NavLinkMatch.All" OnClick="CloseDrawer">
            Inicio
        </MudNavLink>

        <MudNavLink Href="ResponderEncuesta" Icon="@Icons.Material.Filled.Info"
                    OnClick="CloseDrawer">
            Quiénes Somos
        </MudNavLink>

        <MudNavGroup Title="Nuestros Espacios"
                     Icon="@Icons.Material.Filled.Domain" Expanded="false">
            <MudNavLink OnClick="CloseDrawer"
                        Style="background-color:#1d386b; color:white;"
                        Class="nav-link-azul">
                Nuestras Áreas
            </MudNavLink>
            <MudNavLink OnClick="CloseDrawer" Class="nav-link-azul">Patrimonios Nacionales</MudNavLink>
            <MudNavLink OnClick="CloseDrawer" Class="nav-link-azul">Parqueos</MudNavLink>
            <MudNavLink OnClick="CloseDrawer" Class="nav-link-azul">Servicios Adicionales</MudNavLink>
        </MudNavGroup>

        <MudNavLink Href="INTERFER" Icon="@Icons.Material.Filled.Info"
                    OnClick="CloseDrawer">
            INTERFER
        </MudNavLink>

        <MudNavGroup Title="Publicidad"
                     Icon="@Icons.Material.Filled.Campaign" Expanded="false">
            <MudNavLink OnClick="CloseDrawer">Eventos</MudNavLink>
            <MudNavLink OnClick="CloseDrawer">Promociona tu marca y evento</MudNavLink>
        </MudNavGroup>

        <MudNavGroup Title="Transparencia"
                     Icon="@Icons.Material.Filled.Balance" Expanded="false">
            <MudNavLink OnClick="CloseDrawer" Class="nav-link-azul">Información Pública</MudNavLink>
            <MudNavLink OnClick="CloseDrawer" Class="nav-link-azul">Memorias Laborales</MudNavLink>
        </MudNavGroup>

        <MudDivider Class="my-2" />

        <AuthorizeView>
            <Authorized>
                @if (CanAccess("Encuestas"))
                {
                    <MudNavGroup Title="Gestión"
                                 Icon="@Icons.Material.Filled.AdminPanelSettings"
                                 Expanded="false">
                        <MudNavLink Href="Encuesta" OnClick="CloseDrawer">Encuestas</MudNavLink>
                        <MudNavLink Href="VerRespuestasEncuesta" OnClick="CloseDrawer">Respuestas</MudNavLink>
                        <MudNavLink Href="/Reportes/ReporteEncuesta" OnClick="CloseDrawer">Reportes</MudNavLink>
                        <MudNavLink Href="usuarios" OnClick="CloseDrawer">Usuarios</MudNavLink>
                    </MudNavGroup>
                }

                <MudDivider Class="my-2" />

                <MudStack Class="px-4 py-2" Spacing="2">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_nombreUsuario</MudText>
                    <MudButton StartIcon="@Icons.Material.Filled.Logout"
                               Color="Color.Error" Variant="Variant.Outlined"
                               FullWidth="true" OnClick="@HandleLogoutMobile">
                        Cerrar Sesión
                    </MudButton>
                </MudStack>
            </Authorized>

            <NotAuthorized>
                <MudNavLink Href="Login" Icon="@Icons.Material.Filled.Login"
                            OnClick="CloseDrawer">
                    Iniciar Sesión
                </MudNavLink>
            </NotAuthorized>
        </AuthorizeView>
    </MudNavMenu>
</MudDrawer>

@code {
    private string _nombreUsuario = "";
    private List<string> userPermissions = new();
    private bool _disposed = false;
    private bool _drawerOpen = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarUsuario();
        AuthStateProvider.AuthenticationStateChanged += AuthChanged;
    }

    private async Task CargarUsuario()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (auth.User.Identity?.IsAuthenticated == true)
        {
            _nombreUsuario = auth.User.Identity.Name ?? "Usuario";
            userPermissions = await RoleAuth.GetUserPermissionsAsync();
        }
    }

    private bool CanAccess(string p) => userPermissions.Contains(p);

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void CloseDrawer() => _drawerOpen = false;

    private async void AuthChanged(Task<AuthenticationState> task)
    {
        if (_disposed) return;
        await CargarUsuario();
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleLogout()
    {
        await AuthStateProvider.LogoutAsync();
        NavigationManager.NavigateTo("/login", true);
    }

    private async Task HandleLogoutMobile()
    {
        CloseDrawer();
        await AuthStateProvider.LogoutAsync();
        NavigationManager.NavigateTo("/login", true);
    }

    public void Dispose()
    {
        _disposed = true;
        AuthStateProvider.AuthenticationStateChanged -= AuthChanged;
    }
}