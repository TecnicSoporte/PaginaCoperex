            "/Salones", "Ver Salones"),

        new(Icons.Material.Filled.LocalParking,
            "Parqueo",
            "Amplio parque con capacidad para más de 500 vehículos, con seguridad y vigilancia las 24 horas.",
            "/contacto", "Consultar"),

        new(Icons.Material.Filled.Park,
            "Eventos al Aire Libre",
            "Espacios jardinizados perfectos para eventos especiales y experiencias únicas bajo el cielo abierto.",
            "/contacto", "Más Info"),

        new(Icons.Material.Filled.Festival,
            "INTERFER",
            "La feria comercial más importante de fin de año en Guatemala. Un evento imperdible.",
            "/INTERFER", "Conocer INTERFER"),

        new(Icons.Material.Filled.Security,
            "Seguridad",
            "Monitoreo y control profesional dentro de las instalaciones para la tranquilidad de todos.",
            "/contacto", "Consultar"),

        new(Icons.Material.Filled.ConfirmationNumber,
            "Taquillas Disponibles",
            "Sistema de registro y supervisión eficiente del público asistente a los eventos.",
            "/contacto", "Más Info"),
    };
}
