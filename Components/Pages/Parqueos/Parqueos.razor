<!-- ═══ INSTALACIONES ═══ -->
<section class="pk-about">
    <div class="pk-about-grid">
        <div class="pk-about-img-wrap">
            <img src="/ImagenesMyF/Parqueos.png"
                 alt="Parqueos COPEREX" loading="lazy" />
            <div class="pk-about-badge">Desde 1971</div>
            <div class="pk-about-p-tag">P</div>
        </div>

        <div>
            <span class="pk-about-label">Centro de Convenciones #1 en Guatemala</span>
            <h2 class="pk-about-title">Nuestras<br />Instalaciones</h2>

            <p class="pk-about-text">
                En COPEREX entendemos la importancia de ofrecer comodidad desde el momento
                de su llegada. Por ello, contamos con <strong>múltiples áreas de parqueo</strong>
                diseñadas para satisfacer las necesidades de cualquier tipo de evento.
            </p>

            <div class="pk-feature-list">
                @foreach (var f in _features)
                {
                    <div class="pk-feature-item">
                        <div class="pk-feature-icon">
                            <MudIcon Icon="@f.Icon" Style="color:white;" Size="Size.Small" />
                        </div>
                        <span class="pk-feature-text">@f.Texto</span>
                    </div>
                }
            </div>

            <a href="/contacto" class="pk-btn-azul">
                Más Información
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
            </a>
        </div>
    </div>
</section>

<!-- ═══ BENEFICIOS ═══ -->
<section class="pk-benefits" id="beneficios">
    <div class="pk-section-header">
        <span class="pk-section-label">Nuestras Ventajas</span>
        <h2>¿Por Qué Elegir Nuestro Parqueo?</h2>
        <p>Ofrecemos la mejor experiencia de estacionamiento con servicios diseñados para su comodidad y tranquilidad</p>
    </div>

    <div class="pk-benefits-grid">
        @foreach (var b in _beneficios)
        {
            <div class="pk-benefit-card">
                <div class="pk-benefit-icon">
                    <MudIcon Icon="@b.Icon" Style="color:white; font-size:1.8rem;" />
                </div>
                <h3>@b.Titulo</h3>
                <p>@b.Descripcion</p>
            </div>
        }
    </div>
</section>

<!-- ═══ TIPOS DE VEHÍCULOS ═══ -->
<section class="pk-vehicles">
    <div class="pk-section-header">
        <span class="pk-section-label">Todos Bienvenidos</span>
        <h2>Aceptamos Todo Tipo de Vehículos</h2>
        <p>Contamos con espacios adecuados para cualquier tipo de transporte</p>
    </div>

    <div class="pk-vehicles-grid">
        @foreach (var v in _vehiculos)
        {
            <div class="pk-vehicle-card">
                <span class="pk-vehicle-icon">@v.Emoji</span>
                <h3>@v.Nombre</h3>
                <p>@v.Desc</p>
            </div>
        }
    </div>
</section>

<!-- ═══ FAQ ═══ -->
<section class="pk-faq">
    <div class="pk-section-header">
        <span class="pk-section-label">Resolvemos tus Dudas</span>
        <h2>Preguntas Frecuentes</h2>
        <p>Todo lo que necesitas saber sobre nuestro servicio de parqueo</p>
    </div>

    <div class="pk-faq-list">
        @for (int i = 0; i < _faqs.Count; i++)
        {
            var idx = i;
            var faq = _faqs[i];
            var isOpen = _faqOpen == idx;

            <div class="pk-faq-item @(isOpen ? "open" : "")">
                <button class="pk-faq-trigger" @onclick="() => ToggleFaq(idx)">
                    <div class="pk-faq-q">
                        <div class="pk-faq-num">@((idx + 1).ToString("D2"))</div>
                        <span class="pk-faq-question">@faq.Pregunta</span>
                    </div>
                    <MudIcon Icon="@(isOpen ? Icons.Material.Filled.KeyboardArrowUp : Icons.Material.Filled.KeyboardArrowDown)"
                             Class="pk-faq-arrow" />
                </button>
                <div class="pk-faq-body">
                    <p>@faq.Respuesta</p>
                </div>
            </div>
        }
    </div>
</section>

<!-- ═══ HORARIOS ═══ -->
<section class="pk-hours">
