<!-- ═══ DIRECCIÓN + MAPA PEQUEÑO ═══ -->
<section class="ub-address">
    <div class="ub-address-grid">
        <!-- Tarjeta de dirección -->
        <div class="ub-addr-card">
            <div class="ub-addr-header">
                <div class="ub-addr-header-icon">
                    <MudIcon Icon="@Icons.Material.Filled.LocationCity" Style="color:white; font-size:1.8rem;" />
                </div>
                <div>
                    <h3>Parque de la Industria</h3>
                    <p>Sede COPEREX — Desde 1961</p>
                </div>
            </div>

            <div class="ub-addr-body">
                @foreach (var d in _datos)
                {
                    <div class="ub-addr-row">
                        <div class="ub-addr-dot">
                            <MudIcon Icon="@d.Icon" Style="color:white;" Size="Size.Small" />
                        </div>
                        <div class="ub-addr-row-text">
                            <strong>@d.Label</strong>
                            <span>@d.Valor</span>
                        </div>
                    </div>
                }

                <div class="ub-addr-actions">
                    <a href="https://maps.app.goo.gl/o6ejmDFjFM2WY84C9"
                       target="_blank" rel="noopener noreferrer"
                       class="ub-btn-primary">
                        <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Small" />
                        Cómo Llegar
                    </a>
                    <a href="/contacto" class="ub-btn-azul">
                        Contactar
                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                    </a>
                </div>
            </div>
        </div>

        <!-- Mapa embed -->
        <div class="ub-map-wrap">
            <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2730.0156073543812!2d-90.52440588773327!3d14.60903731611401!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8589a3d506898b87%3A0x83c0af9f5a86c02a!2sParque%20de%20la%20Industria!5e0!3m2!1ses-419!2sgt!4v1770744756267!5m2!1ses-419!2sgt"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Mapa COPEREX">
            </iframe>
        </div>
    </div>
</section>

