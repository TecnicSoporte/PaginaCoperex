@page "/Departamento"

@using System.Text.Json
@* @attribute [Authorize] *@
@using PaginaWebCoperex.Models
@using PaginaWebCoperex.Services.DepartamentoServices
@using Microsoft.AspNetCore.Authorization
@using MudBlazor

@inject IDepartamentoService DepartamentoServices
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">

   
    <h3 style="margin-bottom: 20px;">Género</h3>

    <a href="/departamento/agregar"
           class="btn mt-2"
           style="background-color: #1d386b; color: white; border-color: #1d386b;">
        Nuevo Género
    </a>

    <br />

    <MudPaper Elevation="3" Class="pa-4">
        <MudText Typo="Typo.h5" Class="mb-2 text-center" Align="Align.Center">Departamento Disponibles</MudText>

        <MudGrid Class="mt-2">
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Buscar por Departamento"
                              Variant="Variant.Outlined"
                              @bind-Value="searchArea"
                              Immediate="true"
                              DebounceInterval="300"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              AdornmentColor="Color.Primary"
                              OnDebounceIntervalElapsed="Search" />
            </MudItem>
        </MudGrid>

        <br />

        @if (isLoading)
        {
            <div class="spinner-container">
                <img src="/images/world-spinner.gif" alt="Cargando..." class="spinner-image" />
            </div>
        }
        else if (paginatedResult == null || paginatedResult.Items == null || !paginatedResult.Items.Any())
        {
            <MudAlert Severity="Severity.Error">Error al cargar los datos.</MudAlert>
        }
        else
        {
            <MudTable T="DepartamentoTrabajo"
                      ServerData="ServerReload"
                      Dense="true"
                      Hover="true"
                      Bordered="true"
                      Loading="@isLoading"
                      RowClass="cursor-pointer"
                      Class="printable-table">

                <HeaderContent>
                    <MudTh>ID Departamento</MudTh>
                    <MudTh>Departamento</MudTh>
                    <MudTh Class="acciones">Acciones</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd DataLabel="ID Género">@context.DepartamentoId</MudTd>
                    <MudTd DataLabel="Género">@context.NombreDepartamento</MudTd>
                    <MudTd DataLabel="Acciones" Class="acciones">
                        <div class="d-grid gap-2 d-md-block">
                            <a href="/departamento/agregar/@context.DepartamentoId" class="btn btn-warning">Editar</a>
                        </div>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager RowsPerPageString="Géneros por página:"
                                   InfoFormat="@infoFormat"
                                   PageSizeOptions="new int[] { 20, 25, 30, 40, int.MaxValue }"
                                   OnPageChanged="LoadPage"
                                   Class="acciones" />
                </PagerContent>
            </MudTable>
        }
    </MudPaper>

</MudContainer>

@code {
    private MPaginatedResult<DepartamentoTrabajo>? paginatedResult;
    private bool isLoading = false;
    private string infoFormat = "{first_item}-{last_item} de {all_items}";
    private DialogOptions dialogOptions = new() { CloseButton = true, MaxWidth = MaxWidth.Large, FullWidth = true };
    private const int PageSize = 25;
    private string searchArea = "";
    private List<DepartamentoTrabajo> departamento = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadPage(1);
    }

    private async Task LoadPage(int page)
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            paginatedResult = await DepartamentoServices.GetPaginatedAsync(page, PageSize, searchArea);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error en LoadPage: {ex.Message}");
            paginatedResult = new MPaginatedResult<DepartamentoTrabajo>
            {
                Items = new List<DepartamentoTrabajo>(),
                TotalCount = 0,
                PageNumber = page,
                PageSize = PageSize
            };
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task<TableData<DepartamentoTrabajo>> ServerReload(TableState state, CancellationToken cancellationToken)
    {
        isLoading = true;
        try
        {
            var page = state.Page + 1;
            var pageSize = state.PageSize;

            paginatedResult = await DepartamentoServices.GetPaginatedAsync(page, pageSize, searchArea);

            return new TableData<DepartamentoTrabajo>
            {
                Items = paginatedResult?.Items ?? new List<DepartamentoTrabajo>(),
                TotalItems = paginatedResult?.TotalCount ?? 0
            };
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error en ServerReload: {ex.Message}");
            return new TableData<DepartamentoTrabajo>
            {
                Items = new List<DepartamentoTrabajo>(),
                TotalItems = 0
            };
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task Search()
    {
        await LoadPage(1);
    }

    private async Task PrintTable()
    {
        await JSRuntime.InvokeVoidAsync("printTable");
    }
}